# ─────────────────────────────────────────────
# HashiCorp Vault (Fortaleza de Segredos)
# ─────────────────────────────────────────────
# Deixe em branco para usar variáveis do .env como fallback
VAULT_ADDR=http://localhost:8205
VAULT_TOKEN=

# ── Google Gemini API Key ────────────────────
GEMINI_API_KEY=

# Modo debug (false em produção)
DEBUG=False

# ── Estratégia LLM ───────────────────────────
# Opções: local_first | local_only | cloud_only
LLM_STRATEGY=local_first

# Habilita fallback para Gemini quando Ollama falha (apenas para local_first)
CLOUD_FALLBACK=true

# ── Ollama (LLM local) ───────────────────────
USE_LOCAL_LLM=true
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT=600

# ── Tempos de resposta (segundos) ────────────
GEMINI_TIMEOUT=15

# ── CORS ─────────────────────────────────────
# Origens permitidas separadas por vírgula (sem espaços)
ALLOWED_ORIGINS=http://localhost:3000
