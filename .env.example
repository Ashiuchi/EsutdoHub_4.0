# ─────────────────────────────────────────────
# HashiCorp Vault (Fortaleza de Segredos)
# ─────────────────────────────────────────────
# Deixe em branco para usar variáveis do .env como fallback
VAULT_ADDR=http://localhost:8205
VAULT_TOKEN=

# ── Cloud LLM API Keys ───────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

# Modo debug (false em produção)
DEBUG=False

# ── Estratégia LLM ───────────────────────────
# Opções: local_first | local_only | cloud_only | hybrid
LLM_STRATEGY=local_first

# Habilita fallback para Cloud quando Ollama falha (apenas para local_first/hybrid)
CLOUD_FALLBACK=true

# ── Ollama (LLM local) ───────────────────────
USE_LOCAL_LLM=true
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT=600

# ── Tempos de resposta (segundos) ────────────
GEMINI_TIMEOUT=15
GROQ_TIMEOUT=30
OPENROUTER_TIMEOUT=45
NVIDIA_TIMEOUT=60

# ── CORS ─────────────────────────────────────
# Origens permitidas separadas por vírgula (sem espaços)
ALLOWED_ORIGINS=http://localhost:3000
